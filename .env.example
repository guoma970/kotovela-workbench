# Demo 模式：固定走本地 Mock 数据，适合演示
VITE_MODE=demo
VITE_DATA_SOURCE=mock
VITE_POLLING_ENABLED=false
VITE_POLLING_INTERVAL_MS=20000
VITE_VISIBILITY_REFRESH=true
VITE_FALLBACK_TO_MOCK=true
VITE_OFFICE_INSTANCES_API_PATH=/api/office-instances

# Internal 模式可改为（轮询默认 5s，也可设 VITE_POLLING_INTERVAL_MS）：
# VITE_MODE=internal
# VITE_DATA_SOURCE=openclaw
# VITE_POLLING_ENABLED=true
# VITE_POLLING_INTERVAL_MS=5000
