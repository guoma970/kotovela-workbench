# Local development example
# VERCEL_OIDC_TOKEN is injected by Vercel during CI/CD deploys.
# Do not set it in local development files.

# OPENCLAW_PROJECT_ROOT=/absolute/path/to/kotovela-workbench
# OPENCLAW_RUNNER_ROOT=/absolute/path/to/openclaw-runner
# TASK_BOARD_FILE=/absolute/path/to/tasks-board.json
# TASK_NOTIFY_LOG_FILE=/absolute/path/to/task-notifications.json
# MEMORY_STORE_FILE=/absolute/path/to/data/scheduler-memory.json
# TEMPLATE_POOL_FILE=/absolute/path/to/data/scheduler-template-pool.json
# CONTENT_LEARNING_FILE=/absolute/path/to/data/content-learning.json
# AUDIT_LOG_FILE=/absolute/path/to/server/data/audit-log.json
# MODE_STATE_FILE=/absolute/path/to/server/data/system-mode.internal.json
# ALLOWED_ORIGIN=http://localhost:5173
# OFFICE_INSTANCES_UPSTREAM_URL=https://example.com/api/office-instances
# OFFICE_INSTANCES_UPSTREAM_ALLOW_HOSTS=example.com
