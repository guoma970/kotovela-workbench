{
  "name": "openclaw-workbench",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "node scripts/run-stabilization-suite.mjs",
    "capture": "node scripts/capture-dev62.mjs",
    "capture:dev64": "node scripts/capture-dev64.mjs",
    "capture:ui-01": "node scripts/capture-dev-ui-01.mjs",
    "preview": "vite preview --port 4173 --strictPort",
    "sync:office-snapshot": "node scripts/export-office-snapshot.mjs",
    "dev:demo": "vite --mode demo --port 5173 --strictPort",
    "dev:internal": "vite --mode internal --port 5173 --strictPort",
    "check:office": "node scripts/check-office-local.mjs",
    "check:office-api": "node scripts/check-office-api.mjs",
    "check:office-readonly-gateway": "node scripts/check-office-readonly-gateway.mjs",
    "check:xiguo-dispatch": "node --experimental-strip-types scripts/check-xiguo-dispatch.mjs",
    "build:demo": "tsc -b && node scripts/verify-demo-build-safe.mjs && vite build --mode demo",
    "build:internal": "tsc -b && vite build --mode internal",
    "build:opensource": "tsc -b && vite build --mode opensource",
    "serve:office-api": "tsx scripts/office-api-server.ts",
    "serve:office-readonly-gateway": "tsx scripts/office-readonly-gateway.ts"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.0",
    "@vercel/node": "^5.3.25",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "playwright": "^1.59.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "tsx": "^4.20.5",
    "vite": "^8.0.1"
  }
}
